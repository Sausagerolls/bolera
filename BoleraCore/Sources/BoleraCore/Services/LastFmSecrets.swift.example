// Template for local-only Last.fm credentials.
//
// SETUP:
//   1. Register an app at https://www.last.fm/api/account/create
//   2. Copy this file to LastFmSecrets.swift (same directory)
//   3. Paste your API Key + Shared Secret below
//
// LastFmSecrets.swift is gitignored so credentials stay on your machine.
// If both values remain as the YOUR_… placeholders, Last.fm features
// (Similar Artists, bios, smarter daily mixes, scrobbling, mood mixes)
// will simply turn themselves off at runtime.

enum LastFmSecrets {
    static let apiKey    = "YOUR_BOLERA_LASTFM_API_KEY"
    static let apiSecret = "YOUR_BOLERA_LASTFM_SHARED_SECRET"
}
